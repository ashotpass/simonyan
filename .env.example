APP_NAME="Simonyan and Sons"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://simonyanslawfirm.am
APP_TIMEZONE=Asia/Yerevan
APP_LOCALE=hy
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Railway MySQL plugin variables (no underscore between MYSQL and the rest).
DB_CONNECTION=mysql
MYSQLHOST=
MYSQLPORT=3306
MYSQLDATABASE=railway
MYSQLUSER=root
MYSQLPASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=public
FILAMENT_FILESYSTEM_DISK=public

INERTIA_SSR_ENABLED=true
INERTIA_SSR_URL=http://127.0.0.1:13714

# Admin bootstrap (used only on first deploy if the users table is empty).
ADMIN_EMAIL=
ADMIN_PASSWORD=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="info@simonyanslawfirm.am"
MAIL_FROM_NAME="${APP_NAME}"
